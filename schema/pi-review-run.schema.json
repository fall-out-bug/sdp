{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdp.dev/schema/pi-review-run/v1",
  "title": "SDP Pi Review Run",
  "description": "Telemetry manifest for one sdp pi-review run. Raw model text lives in referenced artifacts, not in this manifest.",
  "type": "object",
  "required": [
    "run_id",
    "timestamp",
    "scope",
    "context_packet",
    "models",
    "test_evidence",
    "verdict_ref"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "feature": {
      "type": "string",
      "pattern": "^F\\d{3}$"
    },
    "workstreams": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "scope": {
      "type": "object",
      "required": ["mode", "base", "reviewed_files"],
      "properties": {
        "mode": {
          "type": "string",
          "enum": ["auto", "working-tree", "branch"]
        },
        "base": {
          "type": "string"
        },
        "branch": {
          "type": "string"
        },
        "head_sha": {
          "type": "string"
        },
        "pr_number": {
          "type": ["integer", "null"],
          "minimum": 1
        },
        "reviewed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "context_packet": {
      "type": "object",
      "required": ["path", "sha256", "diff_sha256", "rules_sha256", "file_hashes"],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        },
        "diff_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "rules_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "test_evidence_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "file_hashes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["path", "sha256"],
            "properties": {
              "path": {
                "type": "string"
              },
              "sha256": {
                "$ref": "#/$defs/sha256"
              }
            }
          }
        }
      }
    },
    "test_evidence": {
      "type": "object",
      "required": ["command", "exit_code", "passed", "artifact_path"],
      "properties": {
        "command": {
          "type": "string"
        },
        "exit_code": {
          "type": "integer"
        },
        "passed": {
          "type": "boolean"
        },
        "artifact_path": {
          "type": "string"
        },
        "duration_ms": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "models": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["provider", "model", "role", "status", "artifact_path"],
        "properties": {
          "provider": {
            "type": "string"
          },
          "model": {
            "type": "string"
          },
          "role": {
            "type": "string",
            "enum": ["reviewer", "synthesizer", "fallback"]
          },
          "status": {
            "type": "string",
            "enum": ["ok", "failed", "skipped"]
          },
          "artifact_path": {
            "type": "string"
          },
          "latency_ms": {
            "type": "integer",
            "minimum": 0
          },
          "usage": {
            "type": "object",
            "additionalProperties": true
          },
          "error": {
            "type": "string"
          }
        }
      }
    },
    "verdict_ref": {
      "type": "object",
      "required": ["path", "sha256"],
      "properties": {
        "path": {
          "type": "string"
        },
        "sha256": {
          "$ref": "#/$defs/sha256"
        }
      }
    }
  },
  "$defs": {
    "sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
