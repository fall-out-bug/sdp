{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdp.dev/findings/docs-findings/v1",
  "title": "DocsFindings",
  "description": "Schema for GitHub CI documentation violation findings that can be ingested by local agents",
  "type": "object",
  "required": [
    "spec_version",
    "findings_id",
    "timestamp",
    "source",
    "findings"
  ],
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^v\\d+\\.\\d+$",
      "description": "Schema version for compatibility tracking",
      "examples": ["v1.0", "v1.1"]
    },
    "findings_id": {
      "type": "string",
      "format": "uuid",
      "description": "Unique identifier for this findings report"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when findings were generated"
    },
    "source": {
      "type": "object",
      "required": ["check_name", "workflow", "run_id"],
      "properties": {
        "check_name": {
          "type": "string",
          "description": "Name of the CI check that generated findings",
          "examples": ["sdp-doc-sync", "markdown-link-check"]
        },
        "workflow": {
          "type": "string",
          "description": "GitHub Actions workflow name",
          "examples": ["CI", "Documentation Check"]
        },
        "run_id": {
          "type": "integer",
          "description": "GitHub Actions run ID"
        },
        "run_number": {
          "type": "integer",
          "description": "GitHub Actions run number"
        },
        "repository": {
          "type": "string",
          "description": "Repository in owner/repo format",
          "examples": ["fall-out-bug/sdp_lab"]
        },
        "branch": {
          "type": "string",
          "description": "Branch name",
          "examples": ["feature/F077-findings-schema"]
        },
        "commit_sha": {
          "type": "string",
          "description": "Git commit SHA"
        }
      }
    },
    "configuration": {
      "type": "object",
      "properties": {
        "check_links": {
          "type": "boolean",
          "description": "Whether link checking was enabled"
        },
        "strict_mode": {
          "type": "boolean",
          "description": "Whether strict mode was enabled"
        },
        "changelog_mode": {
          "type": "boolean",
          "description": "Whether changelog update check was enabled"
        }
      }
    },
    "findings": {
      "type": "array",
      "description": "List of documentation violations found",
      "items": {
        "type": "object",
        "required": ["finding_key", "severity", "category", "file", "message"],
        "properties": {
          "finding_key": {
            "type": "string",
            "description": "Unique key for deduplication - hash of file+category+target+code",
            "pattern": "^[a-f0-9]{16}$",
            "examples": ["b2c3d4e5f6789012"]
          },
          "severity": {
            "type": "string",
            "enum": ["error", "warning", "info", "hint"],
            "description": "Finding severity level"
          },
          "category": {
            "type": "string",
            "enum": [
              "broken_link",
              "missing_section",
              "outdated_reference",
              "formatting",
              "changelog",
              "consistency",
              "accessibility",
              "spelling",
              "structure"
            ],
            "description": "Category of documentation violation"
          },
          "code": {
            "type": "string",
            "description": "Machine-readable error code",
            "examples": ["LINK_404", "MISSING_CHANGELOG_ENTRY", "BROKEN_ANCHOR"]
          },
          "file": {
            "type": "string",
            "description": "Relative path to the file with the issue",
            "examples": ["docs/protocol/CONTRACTS.md"]
          },
          "line": {
            "type": "integer",
            "minimum": 1,
            "description": "Line number where the issue was found (1-indexed)"
          },
          "column": {
            "type": "integer",
            "minimum": 1,
            "description": "Column number where the issue was found (1-indexed)"
          },
          "end_line": {
            "type": "integer",
            "minimum": 1,
            "description": "End line number for multi-line issues"
          },
          "message": {
            "type": "string",
            "description": "Human-readable description of the issue",
            "examples": ["Link to 'schema/contracts/old.schema.json' does not exist"]
          },
          "remediation": {
            "type": "object",
            "description": "Remediation hints for fixing the issue",
            "properties": {
              "hint": {
                "type": "string",
                "description": "Brief hint on how to fix the issue",
                "examples": ["Update link to point to ../../schema/contracts/runtime-decision.schema.json"]
              },
              "action": {
                "type": "string",
                "enum": ["add", "update", "remove", "rename", "fix", "create"],
                "description": "Suggested action type"
              },
              "suggested_fix": {
                "type": "string",
                "description": "Suggested replacement text or value"
              },
              "doc_url": {
                "type": "string",
                "format": "uri",
                "description": "Link to relevant documentation"
              }
            }
          },
          "context": {
            "type": "object",
            "description": "Additional context about the finding",
            "properties": {
              "link_target": {
                "type": "string",
                "description": "The target URL or path of a broken link"
              },
              "link_text": {
                "type": "string",
                "description": "The anchor text of a link"
              },
              "section": {
                "type": "string",
                "description": "Section heading where issue was found"
              },
              "expected": {
                "type": "string",
                "description": "Expected value or format"
              },
              "actual": {
                "type": "string",
                "description": "Actual value found"
              },
              "related_files": {
                "type": "array",
                "items": {"type": "string"},
                "description": "Other files related to this finding"
              }
            }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "Summary statistics",
      "properties": {
        "total": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of findings"
        },
        "by_severity": {
          "type": "object",
          "properties": {
            "error": {"type": "integer", "minimum": 0},
            "warning": {"type": "integer", "minimum": 0},
            "info": {"type": "integer", "minimum": 0},
            "hint": {"type": "integer", "minimum": 0}
          }
        },
        "by_category": {
          "type": "object",
          "additionalProperties": {"type": "integer", "minimum": 0},
          "description": "Count of findings by category"
        },
        "links_checked": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of links checked"
        },
        "files_checked": {
          "type": "integer",
          "minimum": 0,
          "description": "Total number of files checked"
        }
      }
    }
  }
}
