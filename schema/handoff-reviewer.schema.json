{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdp.dev/schema/handoff-reviewer/v1",
  "title": "Reviewer Handoff",
  "description": "Structured handoff from reviewer. Verdict gates the pipeline: approve, needs_changes, or reject.",
  "type": "object",
  "required": [
    "verdict",
    "findings",
    "suggestions",
    "risk_assessment"
  ],
  "properties": {
    "verdict": {
      "type": "string",
      "description": "Gate verdict: approve -> Succeeded, needs_changes -> rework, reject -> Failed",
      "enum": ["approve", "needs_changes", "reject"]
    },
    "findings": {
      "type": "array",
      "description": "Review findings (issues identified)",
      "items": { "type": "string" }
    },
    "suggestions": {
      "type": "array",
      "description": "Suggestions for improvement",
      "items": { "type": "string" }
    },
    "risk_assessment": {
      "type": "string",
      "description": "Reviewer's residual risk assessment"
    }
  }
}
