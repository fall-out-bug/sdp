{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sdp.dev/contracts/instructions/v1",
  "title": "SDP Instructions Contract",
  "description": "Machine-readable next-step instruction payload used by sdp next and embedded in sdp status.",
  "type": "object",
  "additionalProperties": false,
  "required": ["action_id", "command", "reason", "confidence", "category", "version"],
  "properties": {
    "action_id": {
      "type": "string",
      "minLength": 1
    },
    "command": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "category": {
      "type": "string",
      "enum": ["execution", "recovery", "planning", "information", "setup"]
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "alternatives": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["command", "reason"],
        "properties": {
          "command": { "type": "string", "minLength": 1 },
          "reason": { "type": "string", "minLength": 1 }
        }
      }
    },
    "required_context": {
      "type": "object",
      "additionalProperties": true
    },
    "optional_context": {
      "type": "object",
      "additionalProperties": true
    },
    "policy_expectations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "evidence_expectations": {
      "type": "array",
      "items": { "type": "string" }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
